{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/public/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.moneykonnect.in" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/sync/leads-to-sheets", "schedule": "0 19 * * *" },
    { "path": "/api/backup/drive", "schedule": "30 18 * * *" },
    { "path": "/api/cron/trello-sync", "schedule": "30 12 * * *" }
  ]
}
